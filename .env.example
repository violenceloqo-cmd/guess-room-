# ──────────────────────────────────────────────────────────────────────────
# Room Royale — environment configuration
# Copy to `.env` and fill in. NEVER commit the real .env.
# ──────────────────────────────────────────────────────────────────────────

# ---- Runtime ----
NODE_ENV=development
PORT=8787

# ---- Solana ----
# cluster: devnet | mainnet-beta | testnet
SOLANA_CLUSTER=devnet
# Use a paid RPC for mainnet (Helius/Triton/QuickNode). Public RPC is fine for devnet.
SOLANA_RPC_URL=https://api.devnet.solana.com

# SPL token mint address that players must hold (from pump.fun). Leave blank until launched.
TOKEN_MINT=
# Minimum token amount (UI / human units, decimals applied automatically) a wallet must hold to play.
TOKEN_MIN_HOLD=10000

# Hot wallet that pays winners. Base58-encoded secret key (array or base58 string).
# Keep ONLY a small float here. NEVER use a wallet that holds large funds.
HOT_WALLET_SECRET=

# ---- Game economics ----
# Prize pool per round, in SOL (host-funded). Winners of the last-standing room split this.
ROUND_POOL_SOL=0.5
# Picking window in seconds (players choose a room).
ROUND_DURATION_SECONDS=60
# Seconds before lock during which new guesses are rejected (0 = lock exactly at end).
ROUND_LOCK_BUFFER_SECONDS=3
# After picking closes, one room is eliminated every N seconds until one remains.
ELIMINATION_INTERVAL_SECONDS=10
# Roll the pool over to the next round when nobody picks the winning room.
ROLLOVER_ON_NO_WINNER=true

# ---- Safety rails ----
# Hard cap: never send more than this many SOL to a single wallet in one payout.
MAX_PAYOUT_SOL=5
# Hard cap: total SOL the engine may pay out in a single round.
MAX_ROUND_PAYOUT_SOL=10
# When true, the engine simulates payouts (no real SOL is sent). Always start here.
DRY_RUN=true

# ---- Host auth ----
# Secret used by the host control panel to start/stop rounds and change config.
HOST_API_SECRET=change-me-to-a-long-random-string

# ---- Supabase ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service-role key: BACKEND ONLY. Full write access. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Anon key: safe for the browser (read-only via RLS).
SUPABASE_ANON_KEY=

# ---- Web (Vite, must be prefixed VITE_) ----
VITE_API_URL=http://localhost:8787
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=
